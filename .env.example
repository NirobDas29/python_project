# OpenWeatherMap API Configuration
# Get your free API key at: https://openweathermap.org/api
OPENWEATHERMAP_API_KEY=your_api_key_here

# Optional: Override the default weather API URL
# OPENWEATHERMAP_API_URL=https://api.openweathermap.org/data/2.5/weather

# NewsAPI Configuration (Optional)
# Get your free API key at: https://newsapi.org/ for better news coverage
# If not provided, the system will use Google News as fallback
# NEWS_API_KEY=your_news_api_key_here

# Optional: Override the default news API URL
# NEWS_API_URL=https://newsapi.org/v2/top-headlines

# Other API Keys (optional)
# OPENAI_API_KEY=your_openai_key_here
